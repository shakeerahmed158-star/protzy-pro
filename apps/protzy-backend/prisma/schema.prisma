//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id String @id @default(uuid())

  name  String?
  phone String  @unique

  role UserRole @default(CUSTOMER)

  otp       String?
  otpExpiry DateTime?

  isBlocked Boolean @default(false)

  hashedRefreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  dealer Dealer?

  orders Order[]

  sellLeads Lead[]

  repairLeads RepairLead[]

  wallet Wallet?

  notifications Notification[]

  reviews         Review[]
  Upload          Upload[]
  Inspection      Inspection[]
  FraudReport     FraudReport[]
  CrmTicket       CrmTicket[]
  AuditLog        AuditLog[]
  SearchHistory   SearchHistory[]
  Carts           Cart[]
  CartItems       CartItem[]
  wishlists       Wishlist[]
  addresses       Address[]
  payments        Payment[]
  campaigns       Campaign[]
  activities      Activity[]
  communications  Communication[]
  loyalty         Loyalty[]
  invoices        Invoice[]
  memberships     UserMembership[]
  payouts         Payout[]
  recommendations Recommendation[]
  personalization Personalization[]
  supportTickets  SupportTicket[]
  reservations    Reservation[]
  returnRequests  ReturnRequest[]

  referralsMade Referral[] @relation("ReferralReferrer")

  referralsReceived Referral[] @relation("ReferralReferredUser")

  @@index([phone])
}

//////////////////////////////////////////////////////
// DEALERS
//////////////////////////////////////////////////////

model Dealer {
  id String @id @default(uuid())

  userId String @unique

  //////////////////////////////////////////////////////
  // BASIC INFO
  //////////////////////////////////////////////////////

  shopName String

  ownerName String?

  contactNumber String?

  alternateNumber String?

  state String?

  gstNumber  String?
  dealerCode String? @unique

  passwordHash String?

  panNumber String?

  aadhaarNumber String?

  profilePhoto String?

  kycVerified Boolean @default(false)

  kycSubmitted Boolean @default(false)

  city    String?
  area    String?
  pincode String?

  address String?
  wallet  Wallet?

  //////////////////////////////////////////////////////
  // DEALER CONFIG
  //////////////////////////////////////////////////////

  type DealerType

  status DealerStatus @default(PENDING)

  rating Float @default(0)

  //////////////////////////////////////////////////////
  // WALLET & EARNINGS
  //////////////////////////////////////////////////////

  walletBalance Float @default(0)

  totalEarnings Float @default(0)

  //////////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // BUSINESS
  //////////////////////////////////////////////////////

  services DealerService[]

  inventories Inventory[]

  leads Lead[]

  repairJobs RepairLead[]

  commissions Commission[]

  //////////////////////////////////////////////////////
  // WALLET
  //////////////////////////////////////////////////////

  walletTransactions WalletTransaction[]

  walletRecharges WalletRecharge[]

  leadTransactions LeadTransaction[]

  //////////////////////////////////////////////////////
  // ORDERS
  //////////////////////////////////////////////////////

  buyOrders BuyOrder[]

  //////////////////////////////////////////////////////
  // SUBSCRIPTIONS
  //////////////////////////////////////////////////////

  subscriptions DealerSubscription[]

  //////////////////////////////////////////////////////
  // REVIEWS
  //////////////////////////////////////////////////////

  reviews Review[]

  //////////////////////////////////////////////////////
  // STAFF
  //////////////////////////////////////////////////////

  technicians Technician[]

  //////////////////////////////////////////////////////
  // OPERATIONS
  //////////////////////////////////////////////////////

  Match Match[]

  Upload Upload[]

  Inspection Inspection[]

  FraudReport FraudReport[]

  CrmTicket CrmTicket[]

  //////////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////////
  Product        Product[]
  Category       Category[]
  OrderItem      OrderItem[]
  CartItem       CartItem[]
  activities     Activity[]
  invoices       Invoice[]
  payouts        Payout[]
  supportTickets SupportTicket[]
  reservations   Reservation[]
  returnRequests ReturnRequest[]

  @@index([type])
  @@index([city, area])
  @@index([status])
}

//////////////////////////////////////////////////////
// DEALER SERVICES
//////////////////////////////////////////////////////

model DealerService {
  id String @id @default(uuid())

  dealerId String?

  type DealerType

  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: SetNull)

  @@unique([dealerId, type])
}

//////////////////////////////////////////////////////
// PRODUCTS MASTER
//////////////////////////////////////////////////////

model Product {
  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // BASIC INFO
  //////////////////////////////////////////////////////

  name String

  brandId String?

  model String

  slug String? @unique

  sku String? @unique

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  categoryId String?

  dealerId String?

  //////////////////////////////////////////////////////
  // CATEGORY
  //////////////////////////////////////////////////////

  category ProductType @default(MOBILE)

  Category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)

  //////////////////////////////////////////////////////
  // DEALER
  //////////////////////////////////////////////////////

  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: SetNull)

  //////////////////////////////////////////////////////
  // PRODUCT INFO
  //////////////////////////////////////////////////////

  shortDescription String?

  description String?

  //////////////////////////////////////////////////////
  // DEVICE SPECS
  //////////////////////////////////////////////////////

  ram String?

  storage String?

  color String?

  batteryHealth Int?

  processor String?

  screenSize String?

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////

  mrp Float?

  sellingPrice Float?

  costPrice Float?

  //////////////////////////////////////////////////////
  // STOCK
  //////////////////////////////////////////////////////

  stock Int @default(0)

  lowStockAlert Int @default(5)

  //////////////////////////////////////////////////////
  // MEDIA
  //////////////////////////////////////////////////////

  thumbnail String?

  images String[]

  //////////////////////////////////////////////////////
  // FLAGS
  //////////////////////////////////////////////////////

  featured Boolean @default(false)

  trending Boolean @default(false)

  recommended Boolean @default(false)

  warrantyAvailable Boolean @default(false)

  emiAvailable Boolean @default(false)

  active Boolean @default(true)

  //////////////////////////////////////////////////////
  // SEO
  //////////////////////////////////////////////////////

  metaTitle String?

  metaDescription String?

  //////////////////////////////////////////////////////
  // ANALYTICS
  //////////////////////////////////////////////////////

  averageRating Float @default(0)

  totalReviews Int @default(0)

  totalSales Int @default(0)

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  inventories Inventory[]

  orders Order[]

  buyOrders BuyOrder[]

  // reviews ProductReview[]

  //////////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////////
  CartItem        CartItem[]
  Wishlist        Wishlist[]
  OrderItem       OrderItem[]
  recommendations Recommendation[]
  reservations    Reservation[]

  @@index([brandId, model])
  @@index([category])
  @@index([categoryId])
  @@index([dealerId])
  @@index([featured])
  @@index([trending])
  @@index([recommended])
  @@index([active])
  @@index([stock])
}

//////////////////////////////////////////////////////
// INVENTORY
//////////////////////////////////////////////////////

model Inventory {
  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  dealerId String?

  productId String

  warehouseId String?

  //////////////////////////////////////////////////////
  // STOCK
  //////////////////////////////////////////////////////

  stock Int @default(1)

  reservedStock Int @default(0)

  soldStock Int @default(0)

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////

  price Float

  offerPrice Float?

  finalPrice Float?

  costPrice Float?

  commissionPercent Float @default(5)

  //////////////////////////////////////////////////////
  // VARIANTS
  //////////////////////////////////////////////////////

  ram String?

  storage String?

  color String?

  sku String? @unique

  //////////////////////////////////////////////////////
  // DETAILS
  //////////////////////////////////////////////////////

  description String?

  images String[]

  //////////////////////////////////////////////////////
  // FLAGS
  //////////////////////////////////////////////////////

  featured Boolean @default(false)

  codAvailable Boolean @default(true)

  returnAvailable Boolean @default(true)

  warrantyAvailable Boolean @default(false)

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////

  status InventoryStatus @default(ACTIVE)

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: SetNull)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  commissions     Commission[]
  OrderItem       OrderItem[]
  CartItems       CartItem[]
  recommendations Recommendation[]
  reservations    Reservation[]

  //////////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////////

  @@index([dealerId])
  @@index([productId])
  @@index([warehouseId])
  @@index([status])
  @@index([stock])
  @@index([price])
  @@index([featured])
}

//////////////////////////////////////////////////////
// SELL LEADS
//////////////////////////////////////////////////////

model Lead {
  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // CUSTOMER
  //////////////////////////////////////////////////////

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // DEVICE
  //////////////////////////////////////////////////////

  brand String

  model String

  variant String?

  storage String?

  condition DeviceCondition

  images String[]

  //////////////////////////////////////////////////////
  // LOCATION
  //////////////////////////////////////////////////////

  city String?

  area String?

  pincode String?

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////

  expectedPrice Float?

  customerPrice Float?

  dealerPrice Float?

  platformMargin Float?

  //////////////////////////////////////////////////////
  // DEALER
  //////////////////////////////////////////////////////

  dealerId String?

  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: SetNull)

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////

  status WorkflowStatus @default(PENDING)

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Match     Match[]

  @@index([brand, model])
  @@index([status])
  @@index([city, area])
}

//////////////////////////////////////////////////////
// REPAIR LEADS
//////////////////////////////////////////////////////

model RepairLead {
  id String @id @default(uuid())

  customerId String

  dealerId String?

  technicianId String?

  brand String

  model String

  issue String

  city String?

  area String?

  estimatedCost Float?

  finalCost Float?

  status WorkflowStatus @default(PENDING)

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  customer User @relation(fields: [customerId], references: [id])

  dealer Dealer? @relation(fields: [dealerId], references: [id])

  technician Technician? @relation(fields: [technicianId], references: [id])

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Match     Match[]

  @@index([status])
  @@index([city, area])
}

//////////////////////////////////////////////////////
// TECHNICIANS
//////////////////////////////////////////////////////

model Technician {
  id String @id @default(uuid())

  dealerId String?

  name String

  phone String

  active Boolean @default(true)

  createdAt DateTime @default(now())

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: SetNull)

  repairLeads RepairLead[]
}

//////////////////////////////////////////////////////
// ORDERS
//////////////////////////////////////////////////////

model Order {
  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // TYPE
  //////////////////////////////////////////////////////

  type OrderType

  //////////////////////////////////////////////////////
  // USER
  //////////////////////////////////////////////////////

  userId String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // SELL LEAD
  //////////////////////////////////////////////////////

  leadId String?

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // REPAIR LEAD
  //////////////////////////////////////////////////////

  repairLeadId String?

  repairLead RepairLead? @relation(fields: [repairLeadId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // PAYMENT
  //////////////////////////////////////////////////////

  paymentMethod PaymentMethod?

  payments      Payment[]
  invoices      Invoice[]
  orderitems    OrderItem[]
  trackings     Tracking[]
  paymentStatus PaymentStatus @default(PENDING)

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////

  totalAmount Float?

  platformFee Float?

  dealerEarning Float?

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////

  status WorkflowStatus @default(PENDING)

  //////////////////////////////////////////////////////
  // OTP
  //////////////////////////////////////////////////////

  deliveryOtp String?

  otpVerified Boolean @default(false)

  //////////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Product   Product? @relation(fields: [productId], references: [id])
  productId String?

  @@index([type])
  @@index([status])
}

//////////////////////////////////////////////////////
// ORDER ITEMS
//////////////////////////////////////////////////////

model OrderItem {
  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  orderId String

  productId String?

  inventoryId String?

  dealerId String?

  //////////////////////////////////////////////////////
  // PRODUCT SNAPSHOT
  //////////////////////////////////////////////////////

  productName String

  productImage String?

  brand String?

  model String?

  ram String?

  storage String?

  color String?

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////

  quantity Int @default(1)

  price Float

  offerPrice Float?

  finalPrice Float

  totalAmount Float

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////

  status OrderItemStatus @default(PENDING)

  //////////////////////////////////////////////////////
  // DELIVERY
  //////////////////////////////////////////////////////

  trackingId String?

  deliveredAt DateTime?

  cancelledAt DateTime?

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  inventory Inventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)

  returnRequests ReturnRequest[]

  trackings Tracking[]

  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: SetNull)

  //////////////////////////////////////////////////////
  // TIMESTAMPS
  //////////////////////////////////////////////////////

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // INDEXES
  //////////////////////////////////////////////////////

  @@index([orderId])
  @@index([productId])
  @@index([inventoryId])
  @@index([dealerId])
  @@index([status])
}

//////////////////////////////////////////////////////
// BUY ORDERS
//////////////////////////////////////////////////////

model BuyOrder {
  id String @id @default(uuid())

  //////////////////////////////////////////////////////
  // CUSTOMER INFO
  //////////////////////////////////////////////////////

  customerName String

  phone String

  //////////////////////////////////////////////////////
  // DEVICE INFO
  //////////////////////////////////////////////////////

  brand String

  model String

  storage String

  condition String

